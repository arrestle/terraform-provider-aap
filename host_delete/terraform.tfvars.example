# Values for host deletion - Host ID 2
# Copy this file to terraform.tfvars and update with your actual values

inventory_id     = 1  # Update this with the correct inventory ID
host_name        = "host-to-delete-id-2"  # Update with actual host name
host_description = "Host ID 2 that will be deleted"
host_enabled     = true
host_variables   = ""
host_groups      = []
delete_timeout   = 120